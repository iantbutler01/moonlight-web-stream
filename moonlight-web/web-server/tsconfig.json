{
  "compilerOptions": {
    "rootDir": "web",
    "outDir": "./dist",
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true
  },
  "include": [
    "web/index.ts",
    "web/stream.ts",
    "web/stream/pipeline/worker.ts",
    "web/**/*.d.ts"
  ]
}
